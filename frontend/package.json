{
  "name": "justgui-frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:astro": "astro check",
    "check:arch": "depcruise src --config .dependency-cruiser.cjs && madge --circular --extensions ts,js,astro src",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright install chromium && playwright test",
    "test:a11y": "pa11y-ci",
    "validate:seo": "node scripts/validate-seo.mjs",
    "seo": "yarn validate:seo",
    "lighthouse": "lhci autorun",
    "size": "size-limit",
    "audit": "npm audit --audit-level=high",
    "a11y": "pa11y-ci",
    "ci:quality": "yarn format:check && yarn lint && yarn typecheck && yarn check:astro && yarn check:arch && yarn test",
    "ci:build": "PUBLIC_APP_ENV=production PUBLIC_SITE_URL=http://127.0.0.1:4321 PUBLIC_WHATSAPP_NUMBER=5511976598853 DATABASE_PATH=./data/ci.sqlite yarn build && yarn size",
    "ci:verify": "PUBLIC_APP_ENV=production PUBLIC_SITE_URL=http://127.0.0.1:4321 PUBLIC_WHATSAPP_NUMBER=5511976598853 DATABASE_PATH=./data/ci.sqlite node scripts/ci-verify.mjs",
    "ci": "yarn ci:quality && yarn ci:build && yarn ci:verify"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^6.3.7",
    "better-sqlite3": "^12.10.0",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@axe-core/playwright": "^4.10.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.51.0",
    "@size-limit/file": "^11.1.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.9",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.22.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^17.4.4",
    "madge": "^8.0.0",
    "pa11y-ci": "^4.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "size-limit": "^11.1.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9",
    "wait-on": "^8.0.3"
  }
}
