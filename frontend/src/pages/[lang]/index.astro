---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/sections/Hero.astro";
import Expertise from "../../components/sections/Expertise.astro";
import Projects from "../../components/sections/Projects.astro";
import About from "../../components/sections/About.astro";
import Contact from "../../components/sections/Contact.astro";
import { getFirstProjectPreview } from "../../data/projects";
import { SUPPORTED_LANGS } from "../../config/seo";

import { isSupportedLang } from "../../utils/localePath";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

export const prerender = false;

const { lang: langParam } = Astro.params;

if (!isSupportedLang(langParam)) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const lang = langParam;
const featuredPreview = await getFirstProjectPreview(lang);
---

<Layout lang={lang}>
  {
    featuredPreview && (
      <link
        rel="preload"
        as="image"
        href={featuredPreview}
        type="image/webp"
        slot="head"
      />
    )
  }
  <Hero lang={lang} />
  <Expertise lang={lang} />
  <Projects lang={lang} />
  <About lang={lang} />
  <Contact lang={lang} />
</Layout>
