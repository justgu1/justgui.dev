---
import { getLang } from "../langs";
import { createT } from "../langs/createT";
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import Analytics from "../components/Analytics.astro";
import FloatingActionCell from "../components/FloatingActionCell.astro";
import WelcomeDialog from "../components/WelcomeDialog.astro";
import AccessibilityPanel from "../components/AccessibilityPanel.astro";

interface Props {
  lang: string;
}

const { lang = "en" } = Astro.props;
const t = createT(getLang(lang));
const showWelcome = Astro.locals.showWelcome ?? false;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="icon" href="/favicons/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SeoHead lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <Analytics />
    <slot name="head" />
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem("justgui.a11y.prefs");
          if (!raw) return;
          var prefs = JSON.parse(raw);
          var root = document.documentElement;
          if (prefs.fontScale) root.dataset.a11yFontScale = prefs.fontScale;
          root.dataset.a11ySpacing = prefs.textSpacing
            ? "comfortable"
            : "default";
          root.dataset.a11yContrast = prefs.highContrast ? "high" : "default";
          root.dataset.a11yVision = prefs.visionFilter || "none";
          root.dataset.a11yMotion = prefs.reduceMotion ? "reduce" : "default";
          root.dataset.a11yFocus = prefs.enhancedFocus ? "enhanced" : "default";
        } catch (_) {}
      })();
    </script>
  </head>

  <body data-show-welcome={showWelcome ? "true" : "false"}>
    <a href="#main-content" class="skip-link">{t("a11y.skipToContent")}</a>
    <Header lang={lang} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} pathname={Astro.url.pathname} />
    <AccessibilityPanel lang={lang} />
    <FloatingActionCell lang={lang} />
    <WelcomeDialog lang={lang} />
  </body>
</html>
