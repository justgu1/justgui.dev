---
import { getLang } from "../langs";
import { createT } from "../langs/createT";
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  lang: string;
}

const { lang = "en" } = Astro.props;
const t = createT(getLang(lang));
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="icon" href="/favicons/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SeoHead lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <Analytics />
  </head>

  <body>
    <a href="#main-content" class="skip-link">{t("a11y.skipToContent")}</a>
    <Header lang={lang} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
