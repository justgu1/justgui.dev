---
import TimelineEntry from "./TimelineEntry.astro";
import { getLang } from "../../langs";
import { createT } from "../../langs/createT";
import { TIMELINE_ENTRY_KEYS } from "../../langs/about-keys";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));
---

<div class="about-timeline">
  {
    TIMELINE_ENTRY_KEYS.map((index) => (
      <TimelineEntry
        year={t(`about.timeline.${index}.year`)}
        chapter={t(`about.timeline.${index}.chapter`)}
        title={t(`about.timeline.${index}.title`)}
        text={t(`about.timeline.${index}.text`)}
      />
    ))
  }
</div>
