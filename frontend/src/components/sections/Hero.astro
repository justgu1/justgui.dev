---
import { getLang } from "../../langs";
import { createT } from "../../langs/createT";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));

const YearsOfExperience = new Date().getFullYear() - 2022;
const cards = [
  {
    title: String(YearsOfExperience),
    subtitle: "+",
    description: t("hero.cards.experience"),
  },
  {
    title: String(YearsOfExperience),
    subtitle: "+",
    description: t("hero.cards.projects"),
  },
  {
    title: "WCAG",
    subtitle: "",
    description: t("hero.cards.wcag-2.1-aa-oriented"),
  },
  {
    title: "99",
    subtitle: "%",
    description: t("hero.accessible-performance"),
  },
];
---

<section id="hero" class="section hero-section" aria-labelledby="hero-heading">
  <div class="section-content">
    <div class="hero-intro">
      <p class="hero-bg-text" aria-hidden="true">GS</p>
      <p class="hero-eyebrow">
        <span class="eyebrow-paragraph" aria-hidden="true"></span>
        {t("hero.eyebrow.first")}
        <span class="eyebrow-separator" aria-hidden="true">•</span>
        {t("hero.eyebrow.second")}
      </p>
      <h1 id="hero-heading" class="hero-title">
        <span class="hero-firstname">{t("firstname")}</span>
        <span class="hero-lastname">{t("lastname")}</span>
      </h1>
      <p class="hero-subtitle">{t("hero.role")}</p>
      <p class="hero-description">{t("hero.description")}</p>

      <nav class="hero-actions" aria-label={t("a11y.heroActions")}>
        <a
          href="#projects"
          class="button button-primary hero-button"
          data-analytics="cta_click"
          data-analytics-location="hero-primary"
        >
          {t("hero.buttons.primary")}
        </a>
        <a
          href="#contact"
          class="button button-secondary hero-button"
          data-analytics="cta_click"
          data-analytics-location="hero-secondary"
        >
          {t("hero.buttons.secondary")}
        </a>
      </nav>
    </div>

    <aside class="hero-aside" aria-label={t("a11y.heroStats")}>
      <ul class="hero-cards-list">
        {
          cards.map((card) => (
            <li class="card-item">
              <article class="card hero-card">
                <h2 class="card-title">
                  <span class="card-title-main">{card.title}</span>
                  {card.subtitle && (
                    <span class="card-title-subtitle"> {card.subtitle}</span>
                  )}
                </h2>
                <p class="card-description">{card.description}</p>
              </article>
            </li>
          ))
        }
      </ul>
      <footer class="hero-status">
        <p class="hero-status-text">
          <span class="available-dot" aria-hidden="true"></span>
          {t("hero.available")}
        </p>
        <a
          href="#contact"
          class="button hero-contact-button"
          data-analytics="cta_click"
          data-analytics-location="hero-contact"
        >
          {t("hero.contact")}
          <span class="arrow-right" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              focusable="false"
              aria-hidden="true"
            >
              <path d="M18 8L22 12L18 16"></path>
              <path d="M2 12H22"></path>
            </svg>
          </span>
        </a>
      </footer>
    </aside>
  </div>
</section>
