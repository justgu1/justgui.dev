---
import HeroAside from "../hero/HeroAside.astro";
import HeroIntro from "../hero/HeroIntro.astro";
import HeroTicker from "../hero/HeroTicker.astro";
import { getProjectCount } from "../../data/projects";
import { getLang } from "../../langs";
import { createT } from "../../langs/createT";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));

const yearsOfExperience = new Date().getFullYear() - 2022;
const projectCount = await getProjectCount(lang);
const cards = [
  {
    title: String(yearsOfExperience),
    subtitle: "+",
    description: t("hero.cards.experience"),
  },
  {
    title: String(projectCount),
    subtitle: "",
    description: t("hero.cards.projects"),
  },
  {
    title: "WCAG",
    subtitle: "",
    description: t("hero.cards.wcag-2.1-aa-oriented"),
  },
  {
    title: "99",
    subtitle: "%",
    description: t("hero.accessible-performance"),
  },
];
---

<section id="hero" class="section hero-section" aria-labelledby="hero-heading">
  <div class="section-content">
    <div class="hero-intro">
      <HeroIntro t={t} />
      <HeroTicker lang={lang} />
    </div>
    <HeroAside t={t} cards={cards} />
  </div>
</section>
