---
import ExpertiseGrid from "../expertise/ExpertiseGrid.astro";
import { getLang } from "../../langs";
import { createT } from "../../langs/createT";
import Section from "../Section.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));
---

<Section
  id="expertise"
  flush
  number={t("sections.expertise.number")}
  description={t("sections.expertise.description")}
  title={t("sections.expertise.title")}
>
  <ExpertiseGrid lang={lang} />
</Section>
