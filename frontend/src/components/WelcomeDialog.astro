---
import { getLang } from "../langs";
import { createT } from "../langs/createT";
import AccessibilityPanelForm from "./AccessibilityPanelForm.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));
const dialogId = "welcome-dialog";
---

<div
  id={dialogId}
  class="welcome-dialog"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${dialogId}-title`}
  hidden
  data-welcome-dialog
>
  <div class="welcome-dialog-backdrop" aria-hidden="true"></div>
  <div class="welcome-dialog-panel">
    <h2 id={`${dialogId}-title`} class="welcome-dialog-title">
      {t("welcome.title")}
    </h2>
    <p class="welcome-dialog-intro">{t("welcome.intro")}</p>

    <section
      class="welcome-dialog-section"
      aria-labelledby={`${dialogId}-cookies`}
    >
      <h3 id={`${dialogId}-cookies`} class="welcome-dialog-section-title">
        {t("welcome.cookiesTitle")}
      </h3>
      <p class="welcome-dialog-section-body">{t("welcome.cookiesBody")}</p>
      <div class="welcome-dialog-actions">
        <button
          type="button"
          class="button button-primary"
          data-welcome-accept-analytics
          aria-pressed="false"
        >
          {t("welcome.acceptAnalytics")}
        </button>
        <button
          type="button"
          class="button button-secondary"
          data-welcome-essential-only
          aria-pressed="false"
        >
          {t("welcome.essentialOnly")}
        </button>
      </div>
    </section>

    <section
      class="welcome-dialog-section"
      aria-labelledby={`${dialogId}-a11y`}
    >
      <h3 id={`${dialogId}-a11y`} class="welcome-dialog-section-title">
        {t("welcome.a11yTitle")}
      </h3>
      <p class="welcome-dialog-section-body">{t("welcome.a11yBody")}</p>
      <div data-welcome-a11y-form>
        <AccessibilityPanelForm lang={lang} showReset={false} />
      </div>
    </section>

    <button
      type="button"
      class="button button-primary welcome-dialog-continue"
      data-welcome-continue
    >
      {t("welcome.continue")}
    </button>
  </div>
</div>

<script src="../scripts/welcome-dialog.client.ts"></script>
