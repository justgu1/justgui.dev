---
import type { createT } from "../../langs/createT";

interface Props {
  t: ReturnType<typeof createT>;
}

const { t } = Astro.props;
const formId = "contact-form";
---

<form
  id={formId}
  class="contact-form"
  aria-label={t("contact.form.label")}
  action="#"
  method="post"
>
  <p class="contact-form-notice">{t("contact.form.pending")}</p>

  <div class="form-group">
    <label for={`${formId}-name`}>{t("contact.form.name")}</label>
    <input
      id={`${formId}-name`}
      name="name"
      type="text"
      autocomplete="name"
      required
      disabled
    />
  </div>

  <div class="form-group">
    <label for={`${formId}-email`}>{t("contact.form.email")}</label>
    <input
      id={`${formId}-email`}
      name="email"
      type="email"
      autocomplete="email"
      required
      disabled
    />
  </div>

  <div class="form-group">
    <label for={`${formId}-message`}>{t("contact.form.message")}</label>
    <textarea id={`${formId}-message`} name="message" required disabled
    ></textarea>
  </div>

  <button type="submit" class="button button-primary contact-submit" disabled>
    {t("contact.form.submit")}
  </button>
</form>
