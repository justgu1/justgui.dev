---
import Title from "./Title.astro";

interface Props {
  id: string;
  number: string;
  description: string;
  title: string;
  headingId?: string;
  flush?: boolean;
}

const {
  id,
  number,
  description,
  title,
  headingId = `${id}-heading`,
  flush = false,
} = Astro.props;
---

<section id={id} class="section" aria-labelledby={headingId}>
  <Title
    number={number}
    description={description}
    title={title}
    headingId={headingId}
  />
  <div class:list={["section-content", flush && "section-content--flush"]}>
    <slot />
  </div>
</section>
