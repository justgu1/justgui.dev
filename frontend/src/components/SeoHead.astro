---
import { getLang } from "../langs";
import { createT } from "../langs/createT";
import { SITE_CONFIG } from "../config/site";
import {
  alternateUrls,
  canonicalUrl,
  isIndexable,
  ogImageUrl,
  ogLocale,
  pageUrl,
  SUPPORTED_LANGS,
} from "../config/seo";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));

const title = t("seo.title");
const description = t("seo.description");
const canonical = canonicalUrl(lang);
const ogImage = ogImageUrl();
const robots = isIndexable() ? "index, follow" : "noindex, nofollow";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${canonical}#website`,
      url: canonical,
      name: title,
      description,
      inLanguage: lang,
    },
    {
      "@type": "Person",
      "@id": `${canonical}#person`,
      name: `${t("firstname")} ${t("lastname")}`,
      jobTitle: t("role"),
      url: canonical,
      sameAs: [
        SITE_CONFIG.linkedinUrl,
        SITE_CONFIG.githubUrl,
        SITE_CONFIG.instagramUrl,
      ],
    },
  ],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonical} />

{
  alternateUrls().map(({ lang: altLang, href }) => (
    <link rel="alternate" hreflang={altLang} href={href} />
  ))
}
<link rel="alternate" hreflang="x-default" href={pageUrl("en")} />

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={t("seo.ogImageAlt")} />
<meta property="og:locale" content={ogLocale(lang)} />
{
  SUPPORTED_LANGS.filter((l) => l !== lang).map((l) => (
    <meta property="og:locale:alternate" content={ogLocale(l)} />
  ))
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={t("seo.ogImageAlt")} />

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
