---
import { getLang } from "../langs";
import { createT } from "../langs/createT";
import AccessibilityPanelForm from "./AccessibilityPanelForm.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = createT(getLang(lang));
const panelId = "accessibility-panel";
---

<div
  id={panelId}
  class="accessibility-panel"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${panelId}-title`}
  hidden
>
  <div class="accessibility-panel-inner">
    <header class="accessibility-panel-header">
      <h2 id={`${panelId}-title`} class="accessibility-panel-title">
        {t("a11yPanel.title")}
      </h2>
      <button
        type="button"
        class="accessibility-panel-close"
        data-a11y-panel-close
        aria-label={t("a11yPanel.close")}
      >
        ×
      </button>
    </header>

    <AccessibilityPanelForm lang={lang} formId={panelId} />
  </div>
</div>
